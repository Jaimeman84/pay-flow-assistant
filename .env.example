# PayFlow GenAI Demo — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The app works WITHOUT an LLM API key.
# Without a key: specialist retrieval and routing work fully,
#   synthesis uses template formatting instead of LLM-generated prose.
# With a key: synthesis generates natural language answers grounded in retrieved data.

# ── LLM Configuration (optional) ─────────────────────────────────────────────

# Provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Model to use for synthesis
# Anthropic options: claude-sonnet-4-20250514
# OpenAI options:    gpt-4o-mini, gpt-4o
LLM_MODEL=claude-sonnet-4-20250514

# Your API key — leave blank to run without LLM synthesis
LLM_API_KEY=

# ── Application Settings ──────────────────────────────────────────────────────

APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
